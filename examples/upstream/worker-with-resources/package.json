		"test:ci": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@cloudflare/workers-tsconfig": "*",
		"@cloudflare/workers-types": "^4.20260518.1",
		"miniflare": "^4.20260515.0",
		"typescript": "~5.8.3",
		"vitest": "4.1.0",
		"wrangler": "^4.92.0"
	}
}
