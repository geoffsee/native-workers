{
	"name": "@fixture/worker-with-resources",
	"private": true,
	"scripts": {
		"cf-typegen": "wrangler types --no-include-runtime && wrangler types ./worker-b/worker-configuration.d.ts -c ./worker-b/wrangler.jsonc --no-include-runtime",
		"deploy": "wrangler deploy",
		"start": "X_LOCAL_EXPLORER=true wrangler dev",
