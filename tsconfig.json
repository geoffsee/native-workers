{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true
  },
  "include": ["src/**/*", "test/**/*", "scripts/**/*"],
  "exclude": ["examples/upstream/**", "node_modules"]
}
